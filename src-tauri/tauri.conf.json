{
  "$schema": "https://raw.githubusercontent.com/nicovell3on/tauri-docs/refs/heads/v2/tooling/cli/schema.json",
  "productName": "Vault",
  "version": "0.1.0",
  "identifier": "com.loom.workspace",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8420",
    "frontendDist": "http://localhost:8420"
  },
  "app": {
    "windows": [
      {
        "title": "Vault",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
